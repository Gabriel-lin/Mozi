{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mozi",
  "version": "0.1.0",
  "identifier": "com.gab.mozi",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Mozi",
        "width": 1200,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "focus": true,
        "additionalBrowserArgs": "--enable-features=msSpeechRecognition"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installMode": "perMachine"
      },
      "wix": {}
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 }
      },
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {}
}
