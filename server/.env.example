# Server
# Optional: home directory for ~/.Mozi/skills and ~/.agents/skills (default: OS user home)
# MOZI_USER_HOME=/home/youruser

MOZI_ENV=development
MOZI_DEBUG=true

# Note: `shared/config.py` resolves this file from disk (not cwd), so uvicorn/celery pick it up even when started from the repo root.

# PostgreSQL
MOZI_DATABASE_URL=postgresql+asyncpg://mozi:mozi_secret@localhost:5432/mozi

# Redis (broker for Celery agent/workflow workers)
# Local API + local worker: redis://localhost:6379
# Docker Compose: compose overrides this with redis://redis:6379 for services — keep host .env as-is for `uv run` on the host only.
MOZI_REDIS_URL=redis://localhost:6379

# --- Agent runs (required for runs to leave `idle`) ---
# The agent API enqueues runs on Celery queue `agent-runs`. Without a consumer, status stays `idle`.
# Same machine + same MOZI_REDIS_URL as the agent API:
#   cd server && uv run celery -A services.sandbox.main:celery_app worker -Q agent-runs -c 2 --loglevel=info
# Or use Docker: docker compose up -d   (includes redis + sandbox-worker)
#
# LLM keys for the worker: same file as the API. Example DeepSeek — uncomment and set:
# MOZI_DEEPSEEK_API_KEY=

# JWT
MOZI_JWT_SECRET=change-me-to-a-random-64-char-string

# GitHub OAuth
MOZI_GITHUB_CLIENT_ID=your_github_client_id
MOZI_GITHUB_CLIENT_SECRET=your_github_client_secret

# CORS
MOZI_CORS_ORIGINS=["http://localhost:3000","tauri://localhost"]

# --- LLM vendors (sandbox worker picks base URL + key by model name; see services/sandbox/llm_routing.py) ---
# Optional tag in API/UI: "openai/gpt-4o", "anthropic/claude-3-5-sonnet-20241022", "vllm/mozi-default", …

# Local vLLM / OpenAI-compatible (only for MOZI_VLLM_MODEL or model id "mozi-default")
MOZI_VLLM_BASE_URL=http://localhost:8000/v1
MOZI_VLLM_MODEL=mozi-default
# MOZI_VLLM_API_KEY=

# OpenAI or Azure OpenAI-compatible (set base URL to your resource)
# MOZI_OPENAI_API_KEY=sk-...
MOZI_OPENAI_BASE_URL=https://api.openai.com/v1
MOZI_DEFAULT_LLM_MODEL=gpt-5.4

# Anthropic
# MOZI_ANTHROPIC_API_KEY=
# MOZI_ANTHROPIC_BASE_URL=
# MOZI_ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
# MOZI_GOOGLE_API_KEY=

# DeepSeek (OpenAI-compatible)
# MOZI_DEEPSEEK_API_KEY=
MOZI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# MOZI_DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# MinIO
MOZI_MINIO_ENDPOINT=localhost:9000
MOZI_MINIO_ACCESS_KEY=minioadmin
MOZI_MINIO_SECRET_KEY=minioadmin

# MCP
MOZI_MCP_SERVER_NAME=mozi
MOZI_MCP_SERVER_VERSION=0.1.0
