{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@mozi/core": ["packages/core/index.ts"],
      "@mozi/core/*": ["packages/core/*/index.ts"],
      "@mozi/core/workflow/views": ["packages/core/workflow/views/index.ts"],
      "@mozi/store": ["packages/store/index.ts"],
      "@mozi/store/*": ["packages/store/*.ts"],
      "@tauri-apps/api/*": ["node_modules/@tauri-apps/api/*"]
    }
  },
  "include": ["src", "packages/core", "packages/store"],
  "exclude": ["node_modules"]
}
