  "scripts": {
    "dev": "vite",
    "server:dev": "cd server && uv run uvicorn services.auth.main:app --reload --port 3001",
    "dev:all": "npm run dev & npm run server:dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix && prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --verbose",
    "format:all": "npm run lint:fix && npm run format:rust",
    "tauri": "cargo tauri",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "db:migrate": "cd server && uv run alembic upgrade head",
    "db:revision": "cd server && uv run alembic revision --autogenerate -m",
    "db:seed": "cd server && uv run python -m scripts.seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "simple-icons": "^16.14.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.5"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  }
}
