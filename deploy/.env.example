# ═══════════════════════════════════════════════════════
# Mozi 生产环境配置 — 复制为 /opt/mozi/.env 并填入真实值
# ═══════════════════════════════════════════════════════

# ─── Docker 镜像 ──────────────────────────────────────
GITHUB_REPOSITORY=Gabriel-lin/Mozi
IMAGE_TAG=latest

# ─── GHCR 登录（私有仓库需要） ───────────────────────
GHCR_USER=your-github-username
GHCR_TOKEN=ghp_xxxxxxxxxxxx

# ─── PostgreSQL ───────────────────────────────────────
MOZI_DB_USER=mozi
MOZI_DB_PASSWORD=your-strong-db-password-here
MOZI_DB_NAME=mozi

# ─── JWT ──────────────────────────────────────────────
MOZI_JWT_SECRET=generate-a-random-64-char-string

# ─── GitHub OAuth ─────────────────────────────────────
MOZI_GITHUB_CLIENT_ID=your_github_client_id
MOZI_GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── CORS ─────────────────────────────────────────────
MOZI_CORS_ORIGINS=["https://your-domain.com"]

# ─── vLLM ─────────────────────────────────────────────
MOZI_VLLM_BASE_URL=http://host.docker.internal:8000/v1
MOZI_VLLM_MODEL=mozi-default

# ─── MinIO ────────────────────────────────────────────
MOZI_MINIO_ACCESS_KEY=your-minio-access-key
MOZI_MINIO_SECRET_KEY=your-minio-secret-key

# ─── MCP ──────────────────────────────────────────────
MOZI_MCP_SERVER_NAME=mozi
MOZI_MCP_SERVER_VERSION=0.1.0
